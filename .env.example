# ------------------------------------------------------------------------------
# This environment file defines non-secret Compose values used by local runs.
#
# Values are grouped by scope to keep host and container concerns separate.
# Host-scoped variables use "H_" and container-scoped variables use "C_".
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Host-scoped variables.
#
# These values are resolved by Compose on the host before containers start.
# ------------------------------------------------------------------------------
H_GID=1000
H_TG_CHAT_ID=123456789
H_TZ=UTC
H_UID=1000

# ------------------------------------------------------------------------------
# Container-scoped variables for service code "ICA".
#
# These values configure the "icloud_alice" worker runtime behaviour.
# ------------------------------------------------------------------------------
C_ICA_BACKUP_INTERVAL_MINUTES=360
C_ICA_CONTAINER_USERNAME=alice
C_ICA_ICLOUD_EMAIL_FILE=/run/secrets/alice_icloud_email
C_ICA_ICLOUD_PASSWORD_FILE=/run/secrets/alice_icloud_password
C_ICA_REAUTH_INTERVAL_DAYS=30
C_ICA_STARTUP_DELAY_SECONDS=15
C_ICA_TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token

# ------------------------------------------------------------------------------
# Container-scoped variables for service code "ICB".
#
# These values configure the "icloud_bob" worker runtime behaviour.
# ------------------------------------------------------------------------------
C_ICB_BACKUP_INTERVAL_MINUTES=360
C_ICB_CONTAINER_USERNAME=bob
C_ICB_ICLOUD_EMAIL_FILE=/run/secrets/bob_icloud_email
C_ICB_ICLOUD_PASSWORD_FILE=/run/secrets/bob_icloud_password
C_ICB_REAUTH_INTERVAL_DAYS=30
C_ICB_STARTUP_DELAY_SECONDS=60
C_ICB_TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
