# ------------------------------------------------------------------------------
# This compose file demonstrates isolated iCloud Drive backup workers.
# ------------------------------------------------------------------------------
name: iclouddd-docker

secrets:
  telegram_bot_token:
    file: ./secrets/telegram_bot_token.txt
  alice_icloud_email:
    file: ./secrets/alice_icloud_email.txt
  alice_icloud_password:
    file: ./secrets/alice_icloud_password.txt
  bob_icloud_email:
    file: ./secrets/bob_icloud_email.txt
  bob_icloud_password:
    file: ./secrets/bob_icloud_password.txt

services:
  icloud_alice:
    container_name: icloud_alice
    build: .
    init: true
    secrets:
      - telegram_bot_token
      - alice_icloud_email
      - alice_icloud_password
    environment:
      TZ: "${H_TZ}"
      PUID: "${H_UID}"
      PGID: "${H_GID}"
      CONTAINER_USERNAME: "${C_ICA_CONTAINER_USERNAME}"
      BACKUP_INTERVAL_MINUTES: "${C_ICA_BACKUP_INTERVAL_MINUTES}"
      STARTUP_DELAY_SECONDS: "${C_ICA_STARTUP_DELAY_SECONDS}"
      REAUTH_INTERVAL_DAYS: "${C_ICA_REAUTH_INTERVAL_DAYS}"
      TELEGRAM_CHAT_ID: "${H_TG_CHAT_ID}"
      TELEGRAM_BOT_TOKEN_FILE: "${C_ICA_TELEGRAM_BOT_TOKEN_FILE}"
      ICLOUD_EMAIL_FILE: "${C_ICA_ICLOUD_EMAIL_FILE}"
      ICLOUD_PASSWORD_FILE: "${C_ICA_ICLOUD_PASSWORD_FILE}"
    volumes:
      - ./data/alice/config:/config
      - ./data/alice/output:/output
      - ./data/alice/logs:/logs
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped

  icloud_bob:
    container_name: icloud_bob
    build: .
    init: true
    secrets:
      - telegram_bot_token
      - bob_icloud_email
      - bob_icloud_password
    environment:
      TZ: "${H_TZ}"
      PUID: "${H_UID}"
      PGID: "${H_GID}"
      CONTAINER_USERNAME: "${C_ICB_CONTAINER_USERNAME}"
      BACKUP_INTERVAL_MINUTES: "${C_ICB_BACKUP_INTERVAL_MINUTES}"
      STARTUP_DELAY_SECONDS: "${C_ICB_STARTUP_DELAY_SECONDS}"
      REAUTH_INTERVAL_DAYS: "${C_ICB_REAUTH_INTERVAL_DAYS}"
      TELEGRAM_CHAT_ID: "${H_TG_CHAT_ID}"
      TELEGRAM_BOT_TOKEN_FILE: "${C_ICB_TELEGRAM_BOT_TOKEN_FILE}"
      ICLOUD_EMAIL_FILE: "${C_ICB_ICLOUD_EMAIL_FILE}"
      ICLOUD_PASSWORD_FILE: "${C_ICB_ICLOUD_PASSWORD_FILE}"
    volumes:
      - ./data/bob/config:/config
      - ./data/bob/output:/output
      - ./data/bob/logs:/logs
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped
