# ------------------------------------------------------------------------------
# This Compose example defines two isolated iCloud Drive backup workers.
#
# The file demonstrates service-level separation, secret-file wiring, and
# host/container environment variable mapping via ".env.example".
# ------------------------------------------------------------------------------
name: iclouddd-docker

# ------------------------------------------------------------------------------
# Define secret-file mappings consumed by worker services.
#
# Each secret maps to a local file path under "./secrets".
# Services reference these by secret name under their "secrets" key.
# ------------------------------------------------------------------------------
secrets:
  telegram_bot_token:
    file: ./secrets/telegram_bot_token.txt
  alice_icloud_email:
    file: ./secrets/alice_icloud_email.txt
  alice_icloud_password:
    file: ./secrets/alice_icloud_password.txt
  bob_icloud_email:
    file: ./secrets/bob_icloud_email.txt
  bob_icloud_password:
    file: ./secrets/bob_icloud_password.txt

# ------------------------------------------------------------------------------
# Define backup worker services.
#
# Each service keeps state in an isolated "./data/<name>" directory tree.
# Shared host values use "H_" variables and service values use "C_<SVC>_"
# variables loaded from ".env.example".
# ------------------------------------------------------------------------------
services:
# ------------------------------------------------------------------------------
# Service "icloud_alice" runs the worker with isolated Alice state paths.
# This service reads configuration from "ALICE_*" and shared host values.
# ------------------------------------------------------------------------------
  icloud_alice:
    container_name: icloud_alice
    build: .
    init: true
    secrets:
      - telegram_bot_token
      - alice_icloud_email
      - alice_icloud_password
    environment:
      TZ: "${H_TZ}"
      PUID: "${C_UID}"
      PGID: "${C_GID}"
      CONTAINER_USERNAME: "${ALICE_CONTAINER_USERNAME}"
      BACKUP_INTERVAL_MINUTES: "${ALICE_BACKUP_INTERVAL_MINUTES}"
      STARTUP_DELAY_SECONDS: "${ALICE_STARTUP_DELAY_SECONDS}"
      REAUTH_INTERVAL_DAYS: "${ALICE_REAUTH_INTERVAL_DAYS}"
      TELEGRAM_CHAT_ID: "${H_TGM_CHAT_ID}"
      TELEGRAM_BOT_TOKEN_FILE: "${ALICE_TELEGRAM_BOT_TOKEN_FILE}"
      ICLOUD_EMAIL_FILE: "${ALICE_ICLOUD_EMAIL_FILE}"
      ICLOUD_PASSWORD_FILE: "${ALICE_ICLOUD_PASSWORD_FILE}"
    volumes:
      - ./data/alice/config:/config
      - ./data/alice/output:/output
      - ./data/alice/logs:/logs
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped

# ------------------------------------------------------------------------------
# Service "icloud_bob" runs the worker with isolated Bob state paths.
# This service reads configuration from "BOB_*" and shared host values.
# ------------------------------------------------------------------------------
  icloud_bob:
    container_name: icloud_bob
    build: .
    init: true
    secrets:
      - telegram_bot_token
      - bob_icloud_email
      - bob_icloud_password
    environment:
      TZ: "${H_TZ}"
      PUID: "${C_UID}"
      PGID: "${C_GID}"
      CONTAINER_USERNAME: "${BOB_CONTAINER_USERNAME}"
      BACKUP_INTERVAL_MINUTES: "${BOB_BACKUP_INTERVAL_MINUTES}"
      STARTUP_DELAY_SECONDS: "${BOB_STARTUP_DELAY_SECONDS}"
      REAUTH_INTERVAL_DAYS: "${BOB_REAUTH_INTERVAL_DAYS}"
      TELEGRAM_CHAT_ID: "${H_TGM_CHAT_ID}"
      TELEGRAM_BOT_TOKEN_FILE: "${BOB_TELEGRAM_BOT_TOKEN_FILE}"
      ICLOUD_EMAIL_FILE: "${BOB_ICLOUD_EMAIL_FILE}"
      ICLOUD_PASSWORD_FILE: "${BOB_ICLOUD_PASSWORD_FILE}"
    volumes:
      - ./data/bob/config:/config
      - ./data/bob/output:/output
      - ./data/bob/logs:/logs
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped
